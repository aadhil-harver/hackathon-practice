# ─── LLM (OpenRouter) ───────────────────────────────────────────────────────
# Get a key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here
INTERVIEW_MODEL=anthropic/claude-sonnet-4.6

# Default max_tokens for every LLM-backed agent except the questions agent.
# OpenRouter rejects requests asking for more tokens than the account can
# afford — lower this if you see 402 errors on parser / skill_match / etc.
INTERVIEW_MAX_TOKENS=800

# Questions agent gets its own cap because it has to emit ≥5 structured items
# and needs more output budget than upstream nodes. Lower this on tight
# OpenRouter budgets (judges report it dropping to ~1200-1300 on free credits).
QUESTIONS_MAX_TOKENS=1200

# ─── LangSmith tracing (optional) ───────────────────────────────────────────
# Set LANGSMITH_TRACING=true to send traces to LangSmith.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=interview-prep

# ─── API server ─────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:8501
